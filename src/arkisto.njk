---
layout: default.njk
title: "Arkisto"
permalink: /arkisto/index.html
---

<main class="content-wrapper container">
    <h1 class="page-title">Uutisarkisto</h1>
    <p class="page-subtitle">Kaikki julkaistut uutiset aikajärjestyksessä uusimmasta vanhimpaan.</p>

    <div class="archive-list">
        {%- for uutinen in collections.uutiset | reverse -%}
            <article class="archive-item">
                <a href="{{ uutinen.url | url }}" class="archive-link">
                    <!-- Pienoiskuva -->
                    <div class="archive-img-wrapper">
                        <img src="{{ uutinen.data.image }}" alt="{{ uutinen.data.title }}">
                    </div>
                    
                    <!-- Tekstisisältö -->
                    <div class="archive-text">
                        <span class="archive-date">{{ uutinen.date | dtf }}</span>
                        <h2>{{ uutinen.data.title }}</h2>
                        <p>{{ uutinen.data.excerpt }}</p>
                    </div>
                </a>
            </article>
        {%- else -%}
            <p>Ei vielä julkaistuja uutisia.</p>
        {%- endfor -%}
    </div>
</main>