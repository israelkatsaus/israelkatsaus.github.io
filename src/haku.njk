---
layout: default.njk
title: "Haku"
permalink: /haku/index.html
---

<main class="content-wrapper container">
    <h1 class="page-title">Hakutulokset</h1>
    <p class="page-subtitle" id="search-status">Kirjoita hakusana yläpalkkiin...</p>

    <!-- Hakutulokset ilmestyvät tähän samaan siistiin listaan kuin arkistossa -->
    <div class="archive-list" id="search-results-list">
        {%- for uutinen in collections.uutiset | reverse -%}
            <article class="archive-item search-js-item" data-title="{{ uutinen.data.title | lower }}" data-excerpt="{{ uutinen.data.excerpt | lower }}">
                <a href="{{ uutinen.url | url }}" class="archive-link">
                    <div class="archive-img-wrapper">
                        <img src="{{ uutinen.data.image }}" alt="{{ uutinen.data.title }}">
                    </div>
                    <div class="archive-text">
                        <span class="archive-date">{{ uutinen.date | dtf }}</span>
                        <h2>{{ uutinen.data.title }}</h2>
                        <p>{{ uutinen.data.excerpt }}</p>
                    </div>
                </a>
            </article>
        {%- endfor -%}
    </div>
</main>

<script>
    // Haetaan osoiteriviltä hakusana (esim. ?q=israel)
    const urlParams = new URLSearchParams(window.location.search);
    const searchQuery = urlParams.get('q');
    const searchInput = document.getElementById('search-input');
    const statusText = document.getElementById('search-status');
    const items = document.querySelectorAll('.search-js-item');

    function suoritaHaku(hakusana) {
        if (!hakusana || hakusana.trim() === "") {
            statusText.textContent = "Kirjoita hakusana yläpalkkiin...";
            items.forEach(item => item.style.display = 'none');
            return;
        }

        const sana = hakusana.toLowerCase().trim();
        let loytyi = 0;

        items.forEach(item => {
            const otsikko = item.getAttribute('data-title');
            const esittely = item.getAttribute('data-excerpt');

            if (otsikko.includes(sana) || esittely.includes(sana)) {
                item.style.display = 'block';
                loytyi++;
            } else {
                item.style.display = 'none';
            }
        });

        statusText.textContent = `Löytyi ${loytyi} hakutulosta sanalla "${hakusana}"`;
    }

    // Suoritetaan haku heti kun sivu latautuu
    if (searchQuery) {
        if (searchInput) searchInput.value = searchQuery;
        suoritaHaku(searchQuery);
    } else {
        // Jos tullaan sivulle ilman hakusanaa, piilotetaan kaikki aluksi
        items.forEach(item => item.style.display = 'none');
    }
</script>