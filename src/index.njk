---
layout: default.njk
title: "Etusivu"
---

<main class="content-wrapper container">
    <!-- ETUSIVUN JAETTU ASENTELU (Isompi uutinen ja sivupalkki) -->
    <div id="front-page-layout">
        
        <!-- PÄÄUUTINEN (Otetaan uusin uutinen collections-kokoelmasta) -->
        <section class="main-article-section">
            {%- for uutinen in collections.uutiset | reverse | limit(1) -%}
                <article class="main-article-card">
                    <a href="{{ uutinen.url | url }}">
                        <div class="img-container-32">
                            <img src="{{ uutinen.data.image }}" alt="{{ uutinen.data.title }}">
                        </div>
                        <h2>{{ uutinen.data.title }}</h2>
                        <p>{{ uutinen.data.excerpt }}</p>
                    </a>
                </article>
            {%- endfor -%}
        </section>

        <!-- 2. OIKEA PUOLI: Seuraavat 6 uutista pienemmässä ruudukossa -->
        <aside class="side-grid">
            {%- for uutinen in collections.uutiset | reverse | offset(1) | limit(6) -%}
                <article class="side-card">
                    <a href="{{ uutinen.url | url }}">
                        <img src="{{ uutinen.data.image }}" alt="{{ uutinen.data.title }}">
                        <h4>{{ uutinen.data.title }}</h4>
                    </a>
                </article>
            {%- endfor -%}
        </aside>

    </div>
</main>